# IBM Watson AI Configuration
WATSON_API_KEY=0120301
WATSON_URL=https://us-south.ml.cloud.ibm.com
WATSON_PROJECT_ID=OOO

# Optional: Watson Model Configuration
WATSON_MODEL_ID=openai/gpt-oss-120b
WATSON_MAX_TOKENS=2000
WATSON_TEMPERATURE=0

# Application Configuration
APP_NAME=Codebase Analyzer
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# Analysis Configuration
MAX_FILE_SIZE_MB=10
MAX_WORKERS=4
ENABLE_AI_ANALYSIS=true

# UI Configuration
THEME=light
WINDOW_WIDTH=1400
WINDOW_HEIGHT=900